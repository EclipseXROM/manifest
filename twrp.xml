<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <!-- TWRP specific remotes -->
    <remote name="twrp" fetch="https://github.com/minimal-manifest-twrp/" />
    <remote name="omnirom" fetch="https://github.com/omnirom/" />
    <remote name="twrp-device" fetch="https://github.com/Tomatcree01/" />
    
    <!-- TWRP core projects -->
    <project name="platform_manifest_twrp_aosp" path="manifest" remote="twrp" revision="twrp-11" />
    <project name="platform_build" path="build" remote="twrp" revision="twrp-11" />
    <project name="platform_system_core" path="system/core" remote="twrp" revision="twrp-11" />
    <project name="platform_system_extras" path="system/extras" remote="twrp" revision="twrp-11" />
    <project name="platform_hardware_libhardware" path="hardware/libhardware" remote="twrp" revision="twrp-11" />
    <project name="platform_frameworks_base" path="frameworks/base" remote="twrp" revision="twrp-11" />
    <project name="platform_frameworks_native" path="frameworks/native" remote="twrp" revision="twrp-11" />
    <project name="platform_packages_apps_Trebuchet" path="packages/apps/Trebuchet" remote="twrp" revision="twrp-11" />
    
    <!-- Device specific projects for Bluejay (Pixel 6a) -->
    <project name="android_device_google_bluejay" path="device/google/bluejay" remote="twrp-device" revision="twrp-13" />
    <project name="android_device_google_gs101" path="device/google/gs101" remote="twrp-device" revision="twrp-13" />
    <project name="android_kernel_google_bluejay" path="kernel/google/bluejay" remote="twrp-device" revision="twrp-13" />
    <project name="android_vendor_google_bluejay" path="vendor/google/bluejay" remote="twrp-device" revision="twrp-13" />
    
    <!-- TWRP recovery specific -->
    <project name="platform_bootable_recovery" path="bootable/recovery" remote="twrp" revision="twrp-11" />
    <project name="team_win_recovery_meat" path="bootable/recovery/meat" remote="twrp" revision="twrp-11" />
    
    <!-- Additional TWRP dependencies -->
    <project name="platform_external_f2fs-tools" path="external/f2fs-tools" remote="twrp" revision="twrp-11" />
    <project name="platform_external_e2fsprogs" path="external/e2fsprogs" remote="twrp" revision="twrp-11" />
    <project name="platform_external_ntfs-3g" path="external/ntfs-3g" remote="twrp" revision="twrp-11" />
    <project name="platform_external_exfat" path="external/exfat" remote="twrp" revision="twrp-11" />
    <project name="platform_external_fuse" path="external/fuse" remote="twrp" revision="twrp-11" />
    
    <!-- Graphics and display -->
    <project name="platform_hardware_qcom_display" path="hardware/qcom/display" remote="omnirom" revision="android-11.0" />
    <project name="platform_hardware_qcom_media" path="hardware/qcom/media" remote="omnirom" revision="android-11.0" />
    
    <!-- Minijail for security -->
    <project name="platform_external_minijail" path="external/minijail" remote="twrp" revision="twrp-11" />
</manifest>
